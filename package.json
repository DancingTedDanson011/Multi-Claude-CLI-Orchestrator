{
  "name": "bridge-clis",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:smoke": "tsx tests/smoke/run.ts",
    "dist": "tsx scripts/build-dist.ts",
    "clean": "pnpm -r exec rimraf dist && rimraf dist-bundle"
  },
  "devDependencies": {
    "@bridge-clis/shared": "workspace:*",
    "@types/node": "^20.11.0",
    "esbuild": "^0.21.0",
    "rimraf": "^5.0.0",
    "tsx": "^4.7.0",
    "typescript": "~5.4.0",
    "vitest": "^1.6.0"
  }
}
